{
  "name": "@computesdk/tensorlake",
  "version": "0.0.1",
  "description": "Tensorlake provider for ComputeSDK - stateful MicroVM sandboxes for agentic applications and LLM-generated code execution",
  "author": "Garrison",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint"
  },
  "dependencies": {
    "@computesdk/provider": "^1.3.0",
    "computesdk": "^2.6.0",
    "tensorlake": "^0.4.48"
  },
  "devDependencies": {
    "@computesdk/test-utils": "workspace:*",
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.57.1",
    "rimraf": "^5.0.10",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "keywords": [
    "computesdk",
    "tensorlake",
    "sandbox",
    "microvm",
    "code-execution",
    "agentic",
    "cloud",
    "compute",
    "provider"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/computesdk/computesdk.git",
    "directory": "packages/tensorlake"
  },
  "homepage": "https://www.computesdk.com",
  "bugs": {
    "url": "https://github.com/computesdk/computesdk/issues"
  }
}
